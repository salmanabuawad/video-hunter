# Copy to /opt/video_hunter/.env on the server and edit.

DATABASE_URL=postgresql+psycopg2://video_hunter:CHANGE_ME@127.0.0.1:5432/video_hunter

UPLOAD_DIR=/opt/video_hunter/data/downloads
THUMB_DIR=/opt/video_hunter/data/thumbs
DOWNLOAD_DIR=/opt/video_hunter/data/downloads

# JWT + cookies
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXP_HOURS=12
COOKIE_SECURE=true

# First-boot admin seed (only used if no admin row exists yet)
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin123

# Uvicorn (systemd may override)
HOST=127.0.0.1
PORT=8030

# Browser origin for the public site
CORS_ORIGINS=https://video.wavelync.com
